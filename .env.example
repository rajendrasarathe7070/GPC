# =============================================================================
# GPC ERP - Environment Configuration
# Government Polytechnic College - Production Environment Template
# =============================================================================

# ------------------------------------------------------------------------------
# Core Django Settings
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production-use-50-plus-chars-complex-string
DJANGO_DEBUG=False
DJANGO_ENV=production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.gpc.ac.in
DJANGO_INTERNAL_IPS=127.0.0.1
SITE_URL=https://gpc.ac.in
SITE_NAME="Government Polytechnic College"

# ------------------------------------------------------------------------------
# Database Configuration
# Supported Engines: postgresql, mysql
# For Supabase: use postgresql with connection string or individual params
# ------------------------------------------------------------------------------
DB_ENGINE=postgresql
DB_NAME=gpc_erp_db
DB_USER=postgres
DB_PASSWORD=secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=require
# Optional: Supabase direct connection URL
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# MySQL Alternative
# DB_ENGINE=mysql
# DB_NAME=gpc_erp_db
# DB_USER=root
# DB_PASSWORD=secure_password_here
# DB_HOST=localhost
# DB_PORT=3306

# ------------------------------------------------------------------------------
# Cache & Session (Redis)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_LOCATION=redis://localhost:6379/1
SESSION_ENGINE=django.contrib.sessions.backends.cache

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict
CSRF_COOKIE_SAMESITE=Strict
X_FRAME_OPTIONS=DENY
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/hour

# ------------------------------------------------------------------------------
# File Storage & CDN
# ------------------------------------------------------------------------------
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/gpc/media
STATIC_URL=/static/
STATIC_ROOT=/var/www/gpc/static
AWS_S3_CUSTOM_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# ------------------------------------------------------------------------------
# Email (SMTP)
# ------------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@gpc.ac.in
EMAIL_HOST_PASSWORD=app_password_here
DEFAULT_FROM_EMAIL="GPC ERP <noreply@gpc.ac.in>"
ADMIN_EMAIL=admin@gpc.ac.in

# ------------------------------------------------------------------------------
# Celery
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ------------------------------------------------------------------------------
# Sentry
# ------------------------------------------------------------------------------
SENTRY_DSN=

# ------------------------------------------------------------------------------
# ClamAV (Virus Scan)
# ------------------------------------------------------------------------------
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_ENABLED=True

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/var/log/gpc
